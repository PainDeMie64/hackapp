{
  "name": "hackapp",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "start": "./dev.sh",
    "dev": "vite dev",
    "build": "vite build",
    "preview": "npm run build && wrangler pages dev",
    "prepare": "svelte-kit sync && (wrangler types src/worker-configuration.d.ts 2>/dev/null || echo '')",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "deploy": "npm run build && wrangler pages deploy",
    "cf-typegen": "wrangler types src/worker-configuration.d.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply hackapp-db --local",
    "db:push": "./scripts/db-push.sh",
    "db:pull": "./scripts/db-pull.sh",
    "db:studio": "drizzle-kit studio",
    "score": "./scripts/score-prospects.sh",
    "ingest": "npx tsx scripts/ingest-pdfs.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.14.7",
    "@playwright/test": "^1.59.1",
    "@sveltejs/adapter-auto": "^7.0.0",
    "@sveltejs/adapter-cloudflare": "^7.2.8",
    "@sveltejs/kit": "^2.50.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.6.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "pdfkit": "^0.18.0",
    "svelte": "^5.51.0",
    "svelte-check": "^4.4.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.4",
    "wrangler": "^4.83.0"
  },
  "dependencies": {
    "@anthropic-ai/bedrock-sdk": "^0.28.1",
    "@anthropic-ai/sdk": "^0.90.0",
    "@types/leaflet": "^1.9.21",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "leaflet": "^1.9.4",
    "lucide-svelte": "^1.0.1",
    "pdf-parse": "^2.4.5",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  }
}
